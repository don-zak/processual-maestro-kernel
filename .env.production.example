# =============================================================================
# Processual Maestro Kernel — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in every variable before deploying.
#
#   cp .env.production.example .env
#
# WARNING:
# - Never commit real secrets to version control.
# - Keep .env ignored by Git.
# - Use a secret manager for cloud deployments.
# - Replace every "replace_with_*" value before production.
# =============================================================================

# --- Runtime Mode ------------------------------------------------------------
ENVIRONMENT=production
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_DEBUG=false

# --- Core API Security -------------------------------------------------------
JWT_SECRET=replace_with_long_random_jwt_secret_minimum_32_bytes
API_KEYS=pmk_bootstrap_replace_with_strong_random_service_key
PROCESSUAL_CRYPTO_KEY_B64=replace_with_base64_encoded_32_byte_encryption_key
CORS_ORIGINS=https://your-frontend.example.com

# --- Database: PostgreSQL ----------------------------------------------------
POSTGRES_USER=processual
POSTGRES_PASSWORD=replace_with_strong_unique_postgres_secret
POSTGRES_DB=processual_db
DATABASE_URL=postgresql+asyncpg://processual:replace_with_strong_unique_postgres_secret@db:5432/processual_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Cache: Redis ------------------------------------------------------------
REDIS_PASSWORD=replace_with_strong_unique_redis_secret
REDIS_URL=redis://:replace_with_strong_unique_redis_secret@redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTHENTICATED=500/minute

# --- Audit -------------------------------------------------------------------
AUDIT_ENABLED=true

# --- Observability: Sentry ---------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Observability: Prometheus ----------------------------------------------
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# --- Observability: Discord Webhooks ----------------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_ADMIN_WEBHOOK_URL=
DISCORD_RATE_LIMIT_SECONDS=2

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=pmk_grafana_admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_unique_grafana_secret

# --- Billing: Lemon Squeezy --------------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_CHECKOUT_SUCCESS_URL=https://your-frontend.example.com/console
LEMONSQUEEZY_CHECKOUT_CANCEL_URL=https://your-frontend.example.com/pricing

LS_VARIANT_STARTER=
LS_VARIANT_STARTER_YEARLY=
LS_VARIANT_PROFESSIONAL=
LS_VARIANT_PROFESSIONAL_YEARLY=
LS_VARIANT_ENTERPRISE=
LS_VARIANT_ENTERPRISE_YEARLY=

# --- Default LLM Provider ----------------------------------------------------
# The customer/deploying organization owns its provider keys and endpoints.
# Processual Maestro does not ship real third-party provider credentials.

LLM_DEFAULT_PROVIDER=opencode

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Google Gemini -----------------------------------------------------------
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# --- DeepSeek ----------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- OpenRouter --------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# --- OpenCode / Ollama / Local OpenAI-Compatible Runtime ---------------------
OPENCODE_API_URL=http://host.docker.internal:11434/v1
OPENCODE_API_KEY=ollama-local
OPENCODE_DEFAULT_MODEL=qwen3-coder:30b

# --- Generic OpenAI-Compatible Provider -------------------------------------
GENERIC_OPENAI_API_KEY=
GENERIC_OPENAI_API_URL=
GENERIC_OPENAI_DEFAULT_MODEL=

# --- CGT Governor ------------------------------------------------------------
CGT_GOVERNOR_ENABLED=true
CGT_GOVERNOR_AUTO_REPAIR=true
CGT_GOVERNOR_MAX_REPAIR_ROUNDS=2

# --- Private Enterprise Quotas ----------------------------------------------
PMK_DEFAULT_API_KEY_QUOTA_LIMIT=50
PMK_ENTERPRISE_PRIVATE_EVALUATION_QUOTA=-1