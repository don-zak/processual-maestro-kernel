# =============================================================================
# Processual Maestro Kernel — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in every variable before deploying.
#   cp .env.production.example .env
#
# WARNING: Never commit secrets to version control. Keep .env in .gitignore.
# =============================================================================

# --- Core API ---------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
API_KEYS=comma-separated-strong-api-keys-for-service-access
PROCESSUAL_CRYPTO_KEY_B64=base64-encoded-32-byte-key-for-report-and-provider-secret-encryption
CORS_ORIGINS=https://your-frontend.example.com

# --- Database (PostgreSQL) ---------------------------------------------------
DATABASE_URL=postgresql+asyncpg://processual:STRONG_DB_PASSWORD@db:5432/processual_db
POSTGRES_USER=processual
POSTGRES_PASSWORD=STRONG_DB_PASSWORD
POSTGRES_DB=processual_db

# --- Cache (Redis) -----------------------------------------------------------
REDIS_URL=redis://:STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=STRONG_REDIS_PASSWORD

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
# Prometheus metrics are enabled by default at /metrics
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# --- LLM Adapters (optional — set only if using LLM features) ----------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_DEFAULT_MODEL=gpt-4o
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
# GEMINI_DEFAULT_MODEL=gemini-2.0-flash
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- Grafana (optional — dashboard only) -------------------------------------
# GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=STRONG_GRAFANA_PASSWORD

# --- Debug (MUST be false in production) -------------------------------------
# API_DEBUG=false
