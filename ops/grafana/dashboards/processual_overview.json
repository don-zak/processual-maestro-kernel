{
  "title": "Processual Maestro Overview",
  "uid": "processual-overview",
  "panels": [
    {
      "title": "HTTP Requests",
      "type": "graph",
      "targets": [
        {"expr": "rate(processual_requests_total[5m])", "legendFormat": "requests"}
      ]
    },
    {
      "title": "Request Latency p95",
      "type": "graph",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(processual_request_latency_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "title": "CGT Evaluations",
      "type": "stat",
      "targets": [
        {"expr": "rate(processual_cgt_evaluations_total[5m])", "legendFormat": "evaluations"}
      ]
    },
    {
      "title": "Fate Rank Distribution",
      "type": "piechart",
      "targets": [
        {"expr": "processual_fate_rank_total", "legendFormat": "{{rank}}"}
      ]
    },
    {
      "title": "Crypto Failures",
      "type": "graph",
      "targets": [
        {"expr": "rate(processual_crypto_failures_total[5m])", "legendFormat": "failures"}
      ]
    },
    {
      "title": "Discord Alerts",
      "type": "graph",
      "targets": [
        {"expr": "rate(processual_discord_alerts_total[5m])", "legendFormat": "alerts"}
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
